{
  "$meta": {
    "name": "Straps Starter · Design Tokens",
    "mode": "light",
    "brand": "Open starter (Inter, fresh mint) — MIT, safe to fork",
    "aliasSyntax": "{group.key} references resolve against this file (e.g. {color.mint}, {radius.card}).",
    "fontNote": "Inter (OFL) named first with system fallbacks; no font binaries shipped."
  },
  "color": {
    "mint": "#4FE39B",
    "mint50": "#ECFDF5",
    "mint100": "#D1FAE5",
    "mint200": "#A7F3D0",
    "mint300": "#6EE7B7",
    "mint500": "#34D399",
    "mint700": "#047857",
    "mint900": "#064E3B",
    "black": "#000000",
    "ink": "#111827",
    "ink2": "#374151",
    "ink3": "#6B7280",
    "muted": "#9CA3AF",
    "white": "#FFFFFF",
    "offwhite": "#FAFAF9",
    "bgsoft": "#F8FAFC",
    "surface3": "#F1F5F9",
    "page": "#F8FAFC",
    "line": "#E5E7EB",
    "linesoft": "#F1F5F9",
    "warn": "#FBBF24",
    "warnTint": "#FEF3C7",
    "warnInk": "#92400E",
    "danger": "#EF4444",
    "dangerTint": "#FEE2E2",
    "dangerInk": "#B91C1C",
    "borderWarn": "#FDE68A",
    "borderDanger": "#FECACA",
    "progressTrack": "#E5E7EB"
  },
  "gradient": {
    "hero": "linear-gradient(180deg,#A7F3D0 0%,#4FE39B 100%)"
  },
  "font": {
    "display": "\"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif",
    "body": "\"Inter\", system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif",
    "mono": "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"
  },
  "typography": {
    "display": { "fontFamily": "{font.display}", "fontWeight": 800, "letterSpacing": "-0.01em", "lineHeight": 1.0 },
    "screenTitle": { "fontFamily": "{font.display}", "fontWeight": 800, "lineHeight": 1.1, "fontSize": "24px" },
    "eyebrow": { "fontFamily": "{font.body}", "fontWeight": 700, "fontSize": "11px", "letterSpacing": "0.08em", "textTransform": "uppercase", "color": "{color.ink3}" },
    "subtitle": { "fontFamily": "{font.body}", "fontWeight": 400, "fontSize": "14px", "lineHeight": 1.4, "color": "{color.ink2}" },
    "label": { "fontFamily": "{font.body}", "fontWeight": 600, "fontSize": "13px", "color": "{color.ink}" },
    "body": { "fontFamily": "{font.body}", "fontWeight": 400, "fontSize": "14px", "lineHeight": 1.5 }
  },
  "radius": {
    "xs": "4px", "sm": "6px", "md": "10px",
    "input": "12px", "chipPad": "8px", "button": "12px", "card": "16px",
    "panel": "18px", "hero": "20px", "pill": "9999px"
  },
  "space": { "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "24px", "6": "32px", "7": "48px", "8": "64px" },
  "shadow": {
    "sm": "0 1px 2px rgba(0,0,0,0.06),0 2px 6px rgba(0,0,0,0.05)",
    "md": "0 4px 12px rgba(0,0,0,0.08),0 12px 28px rgba(0,0,0,0.08)",
    "lg": "0 8px 24px rgba(0,0,0,0.10),0 32px 64px rgba(0,0,0,0.18)",
    "offset": "0 2px 0 0 #000"
  },
  "motion": { "fast": "0.14s", "node": "0.22s", "payload": "0.28s", "fill": "0.5s cubic-bezier(.4,.1,.2,1)" }
}
