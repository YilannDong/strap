{
  "permissions": {
    "allow": [
      "Bash(node:*scripts/strap.mjs*)",
      "Bash(node \"$CLAUDE_PROJECT_DIR/scripts/strap.mjs\"*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/strap.mjs\" check"
          }
        ]
      }
    ]
  }
}
